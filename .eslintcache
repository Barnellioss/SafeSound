ingCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"42"},{"filePath":"60","messages":"61","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"42"},{"filePath":"62","messages":"63","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"64","usedDeprecatedRules":"42"},{"filePath":"65","messages":"66","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"42"},{"filePath":"67","messages":"68","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"42"},{"filePath":"69","messages":"70","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"71","usedDeprecatedRules":"42"},{"filePath":"72","messages":"73","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"42"},{"filePath":"74","messages":"75","errorCount":0,"warningCount":4,"fixableErrorCount":0,"fixableWarningCount":0,"source":"76","usedDeprecatedRules":"42"},{"filePath":"77","messages":"78","errorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":"79","usedDeprecatedRules":"42"},{"filePath":"80","messages":"81","errorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"82","usedDeprecatedRules":"42"},{"filePath":"83","messages":"84","errorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"85","usedDeprecatedRules":"42"},{"filePath":"86","messages":"87","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"C:\\projects\\SafeSoundPush\\SafeSound\\src\\index.js",[],["88","89"],"C:\\projects\\SafeSoundPush\\SafeSound\\src\\App.js",[],"C:\\projects\\SafeSoundPush\\SafeSound\\src\\reportWebVitals.js",[],"C:\\projects\\SafeSoundPush\\SafeSound\\src\\redux\\redux-store.js",["90"],"import React from 'react'\r\nimport { applyMiddleware, combineReducers, createStore } from 'redux'\r\nimport songsReducer from './songsReducer'\r\nimport thunkMiddleware from \"redux-thunk\";\r\n//import { reducer as formReducer } from 'redux-form'\r\n\r\n\r\nlet reducers = combineReducers({\r\n    songsList: songsReducer,\r\n    //form: formReducer\r\n})\r\n\r\nlet store = createStore(reducers, applyMiddleware(thunkMiddleware))\r\n\r\nwindow.store = store\r\n\r\nexport default store;\r\n\r\n","C:\\projects\\SafeSoundPush\\SafeSound\\src\\redux\\songsReducer.js",["91"],"import React from 'react'\r\nimport { songsAPI } from '../api/api'\r\n\r\n\r\nconst SET_SONGS = 'SET_SONGS';\r\nconst SET_AUTHOR = 'SET_AUTHOR';\r\nconst SET_TRACKS = 'SET_TRACKS';\r\nconst SET_FAVORITE = 'SET_FAVORITE';\r\nconst DELETE_FAVORITE = 'DELETE_FAVORITE';\r\n\r\n\r\n\r\nlet initialState = {\r\n    songs: [],\r\n    artist: [],\r\n    tracks: [],\r\n    favorite: []\r\n}\r\n\r\nconst songsReducer = (state = initialState, action) => {\r\n    switch (action.type) {\r\n        case SET_SONGS:\r\n            return {\r\n                ...state,\r\n                songs: action.songs\r\n            }\r\n        case SET_AUTHOR:\r\n            return {\r\n                ...state,\r\n                artist: action.artist\r\n            }\r\n        case SET_TRACKS:\r\n            return {\r\n                ...state,\r\n                tracks: action.track\r\n            }\r\n        case SET_FAVORITE:\r\n            return {\r\n                ...state,\r\n                favorite: [...state.favorite, action.favorite]\r\n            }\r\n        case DELETE_FAVORITE:\r\n            return {\r\n                ...state,\r\n                favorite: state.favorite.filter(item => item.artist !== action.song && item.song !== action.artist)\r\n            }\r\n        default:\r\n            return state\r\n    }\r\n}\r\n\r\nexport const setSongs = (songs) => ({ type: SET_SONGS, songs });\r\nexport const setArtist = (artist) => ({ type: SET_AUTHOR, artist });\r\nexport const setTracks = (track) => ({ type: SET_TRACKS, track })\r\nexport const setFavorite = (favorite) => ({ type: SET_FAVORITE, favorite })\r\nexport const deleteFavorite = (song, artist) => ({ type: DELETE_FAVORITE, song, artist})\r\n\r\n\r\nexport const requestSongs = (number) => {\r\n    return async (dispatch) => {\r\n        let response = await songsAPI.getSongs(number)\r\n        dispatch(setSongs(response))\r\n    }\r\n}\r\n\r\nexport const requestArtist = (artist) => {\r\n    return async (dispatch) => {\r\n        let response = await songsAPI.getArtistData(artist)\r\n        dispatch(setArtist([response]))\r\n    }\r\n}\r\n\r\nexport const searchRequest = (word) => {\r\n    return async (dispatch) => {\r\n        let response = await songsAPI.getSearchData(word)\r\n        dispatch(setTracks(response))\r\n    }\r\n}\r\n\r\n\r\nexport default songsReducer;\r\n\r\n\r\n//let call = songsAPI.getArtistData(\"Starset\")\r\n//window.caller = call","C:\\projects\\SafeSoundPush\\SafeSound\\src\\components\\Header\\Header.jsx",[],"C:\\projects\\SafeSoundPush\\SafeSound\\src\\components\\Songs\\SongsContainer.jsx",["92"],"import React from 'react'\r\nimport { connect } from 'react-redux'\r\nimport { compose } from 'redux'\r\nimport { requestArtist, requestSongs } from '../../redux/songsReducer';\r\nimport Songs from './Songs'\r\n\r\n\r\n\r\nclass SongsContainer extends React.Component {\r\n\r\n    render() {\r\n        return (\r\n            <Songs songs = {this.props.songs}/>\r\n        )\r\n    }\r\n    componentDidMount(){\r\n        this.props.setSongs(20)\r\n    }\r\n}\r\n\r\n\r\n\r\n\r\nlet mapStateToProps = (state) => {\r\n    return {\r\n        songs: state.songsList.songs,\r\n    }\r\n}\r\n\r\n\r\nexport default compose(connect(mapStateToProps, { setSongs: requestSongs}))(SongsContainer)\r\n","C:\\projects\\SafeSoundPush\\SafeSound\\src\\components\\AboutSinger\\AboutSingerContainer.jsx",[],"C:\\projects\\SafeSoundPush\\SafeSound\\src\\components\\Favorite\\FavoritePage.jsx",[],"C:\\projects\\SafeSoundPush\\SafeSound\\src\\components\\SearchPage\\SearchPageContainer.jsx",["93"],"import React from 'react'\r\nimport { connect } from 'react-redux'\r\nimport { compose } from 'redux'\r\nimport SearchPages from './SearchPages';\r\n\r\n\r\n\r\n\r\nlet mapStateToProps = (state) => {\r\n    return {\r\n        tracks: state.songsList.tracks\r\n    }\r\n}\r\n\r\n\r\n\r\n\r\n\r\nexport default compose(connect(mapStateToProps))(SearchPages)\r\n","C:\\projects\\SafeSoundPush\\SafeSound\\src\\api\\api.js",[],"C:\\projects\\SafeSoundPush\\SafeSound\\src\\components\\Songs\\Songs.jsx",[],"C:\\projects\\SafeSoundPush\\SafeSound\\src\\components\\AboutSinger\\AboutSingers.jsx",["94"],"import { nanoid } from 'nanoid';\r\nimport React, { useState } from 'react';\r\nimport AboutSinger from './AboutSinger';\r\nimport styles from './AboutSingers.module.css';\r\n\r\nlet AboutSingers = ({artist}) => {\r\n    \r\n    //let [value, setState] = useState([])\r\n    let arr = Object.values(artist).map(i => i.image).map(a => a[3]).map(d => Object.values(d))\r\n    \r\n    //setState(artist);\r\n    let artistData = artist.map(s => <AboutSinger  image = {arr} key={nanoid()} tags = {artist[0].tags.tag.map(d => d.name)} artistName = {artist[0].name} text = {artist[0].bio.content} />)\r\n       return ( \r\n           <div className={styles.main__container}>\r\n               {artistData}\r\n           </div>\r\n       )\r\n}\r\n\r\nexport default AboutSingers;","C:\\projects\\SafeSoundPush\\SafeSound\\src\\components\\SearchPage\\SearchPages.jsx",[],"C:\\projects\\SafeSoundPush\\SafeSound\\src\\components\\Songs\\Song.jsx",["95","96","97","98"],"import React, { useReducer } from 'react'\r\nimport { NavLink, Route } from 'react-router-dom';\r\nimport { requestArtist, setFavorite } from '../../redux/songsReducer';\r\nimport styles from './Main.module.css'\r\nimport { useDispatch, useSelector } from 'react-redux';\r\nimport { CloseCircleTwoTone, PlusCircleTwoTone } from '@ant-design/icons';\r\n\r\n\r\n\r\n\r\n\r\nlet Song = ({ image, songsName, artist, url }) => {\r\n\r\n    const data = useSelector((state) => state.songsList.favorite)\r\n\r\n    const dispatch = useDispatch()\r\n\r\n    const addFavorite = (artist, song, url) => {\r\n        if (data.length) {\r\n            let length = data.filter(e => e.artist === artist && e.song === song).length\r\n            if (length === 0) {\r\n                dispatch(setFavorite({ artist: artist, song: song, url: url }))\r\n            }\r\n        }\r\n        if (data.length === 0) {\r\n            dispatch(setFavorite({ artist: artist, song: song, url: url}))\r\n        }\r\n    }\r\n\r\n\r\n    return (\r\n        <div className={styles.main__block}>\r\n            <div className={styles.main__items}>\r\n                <div className={styles.main__item}>\r\n                    <img className={styles.band__logo} src={image} alt=\"songs-image\" />\r\n                </div>\r\n                <div className={styles.main__item}>\r\n                    <h3>\r\n                        <NavLink onClick={() => dispatch(requestArtist(artist))} to=\"/about\">{artist.toString()}</NavLink>\r\n                        <span>-</span> {songsName}\r\n                    </h3>\r\n                </div>\r\n                <div className={styles.url}>\r\n                    <a className={styles.href} href={url}>Author's Page</a>\r\n                    <div className={styles.buttons}>\r\n                        <PlusCircleTwoTone onClick={() => addFavorite(artist, songsName, url)} twoToneColor=\"#52c41a\" style={{ paddingLeft: \"10px\", cursor: 'pointer' }} />\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    )\r\n}\r\n\r\nexport default Song;\r\n","C:\\projects\\SafeSoundPush\\SafeSound\\src\\components\\AboutSinger\\AboutSinger.jsx",["99","100","101"],"import { nanoid } from 'nanoid'\r\nimport React from 'react'\r\nimport styles from './AboutSingers.module.css'\r\nimport Tags from './Tags/Tags'\r\n\r\n\r\n\r\nlet AboutSinger = ({ image, artistName, text, tags }) => {\r\n\r\n    let tagCalling = tags.map(d => <Tags key={nanoid()} tag={d} />)\r\n\r\n\r\n    return (\r\n            <div className={styles.main__items__container}>\r\n                <div className={styles.main__items}>\r\n                    <div className={styles.main__item, styles.main__image_block}>\r\n                        <div>\r\n                        <img src={image} alt=\"artist-image\"/>\r\n                        </div>\r\n                        <div>                      \r\n                            <h3 className={styles.main__item_header}>{artistName}</h3>\r\n                        </div>\r\n                    </div>\r\n                    <div className={styles.main__item}>\r\n                        <p className={styles.main__text}>\r\n                            {text}\r\n                        </p>\r\n                    </div>\r\n                    <div className={styles.main__item, styles.main__tags_grid }>\r\n                        {tagCalling}\r\n                    </div>\r\n                </div >\r\n            </div >\r\n    )\r\n}\r\n\r\nexport default AboutSinger;\r\n","C:\\projects\\SafeSoundPush\\SafeSound\\src\\components\\SearchPage\\SearchPage.jsx",["102","103"],"import React, { useEffect, useRef, useState } from 'react'\r\nimport { useDispatch } from 'react-redux'\r\n//import { Field, reduxForm } from 'redux-form'\r\nimport styles from './SearchPages.module.css'\r\nimport { searchRequest } from '../../redux/songsReducer'\r\n\r\n\r\n\r\nlet SearchPage = (props) => {\r\n    const [state, setState] = useState('')\r\n\r\n\r\n    //const input = useRef()\r\n    const dispatch = useDispatch()\r\n\r\n  \r\n    /*useEffect(() => {\r\n        searchRequest()\r\n    })*/\r\n\r\n\r\n    return (\r\n        <div className={styles.main__block}>\r\n            <div className={styles.form}>\r\n                <div className={styles.form__item}>\r\n                    <input className={styles.search__input} value={state} onChange={(event) => setState(event.target.value)} component={'input'} autoComplete=\"off\" placeholder={\"Song's Search\"} />\r\n                    <button onClick={()=> dispatch(searchRequest(state))} className={styles.search__btn}>Search</button>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    )\r\n}\r\n\r\n//export const InputReduxForm = reduxForm({form: 'inputData'})(SearchPage)\r\n\r\nexport default SearchPage;","C:\\projects\\SafeSoundPush\\SafeSound\\src\\components\\SearchPage\\songsList\\songItem.jsx",["104","105"],"import { CloseCircleTwoTone, PlusCircleTwoTone } from '@ant-design/icons';\r\nimport React, { useEffect } from 'react'\r\nimport { useDispatch, useSelector } from 'react-redux';\r\nimport { setFavorite } from '../../../redux/songsReducer';\r\nimport styles from '../SearchPages.module.css'\r\n\r\nlet SongItem = ({ artist, songName, url }) => {\r\n\r\n    const data = useSelector((state) => state.songsList.favorite)\r\n\r\n    const dispatch = useDispatch()\r\n\r\n    const addFavorite = (artist, song) => {\r\n        if (data.length) {\r\n            let length = data.filter(e => e.artist === artist && e.song === song).length\r\n            if (length === 0) {\r\n                dispatch(setFavorite({ artist: artist, song: song, url: url }))\r\n            }\r\n        }\r\n        if (data.length === 0) {\r\n            dispatch(setFavorite({ artist: artist, song: song, url: url }))\r\n        }\r\n    }\r\n\r\n    return (\r\n        <div className={styles.main__items}>\r\n            <h3 className={styles.title}>\r\n                {artist} <span>-</span> {songName}\r\n            </h3>\r\n            <div className={styles.url}>\r\n                <a className={styles.href} href={url}>Author's Page</a>\r\n                <div className={styles.buttons}>\r\n                    <PlusCircleTwoTone onClick={() => addFavorite(artist, songName, url)} twoToneColor=\"#52c41a\" style={{ paddingLeft: \"10px\", cursor: 'pointer' }} />\r\n                </div>\r\n            </div>\r\n        </div>\r\n    )\r\n}\r\n\r\nexport default SongItem;","C:\\projects\\SafeSoundPush\\SafeSound\\src\\components\\AboutSinger\\Tags\\Tags.jsx",[],{"ruleId":"106","replacedBy":"107"},{"ruleId":"108","replacedBy":"109"},{"ruleId":"110","severity":1,"message":"111","line":1,"column":8,"nodeType":"112","messageId":"113","endLine":1,"endColumn":13},{"ruleId":"110","severity":1,"message":"111","line":1,"column":8,"nodeType":"112","messageId":"113","endLine":1,"endColumn":13},{"ruleId":"110","severity":1,"message":"114","line":4,"column":10,"nodeType":"112","messageId":"113","endLine":4,"endColumn":23},{"ruleId":"110","severity":1,"message":"111","line":1,"column":8,"nodeType":"112","messageId":"113","endLine":1,"endColumn":13},{"ruleId":"110","severity":1,"message":"115","line":2,"column":17,"nodeType":"112","messageId":"113","endLine":2,"endColumn":25},{"ruleId":"110","severity":1,"message":"116","line":1,"column":17,"nodeType":"112","messageId":"113","endLine":1,"endColumn":27},{"ruleId":"110","severity":1,"message":"117","line":2,"column":19,"nodeType":"112","messageId":"113","endLine":2,"endColumn":24},{"ruleId":"110","severity":1,"message":"118","line":6,"column":10,"nodeType":"112","messageId":"113","endLine":6,"endColumn":28},{"ruleId":"119","severity":1,"message":"120","line":35,"column":21,"nodeType":"121","endLine":35,"endColumn":88},{"ruleId":"122","severity":1,"message":"123","line":16,"column":54,"nodeType":"124","messageId":"125","endLine":16,"endColumn":55},{"ruleId":"119","severity":1,"message":"120","line":18,"column":25,"nodeType":"121","endLine":18,"endColumn":62},{"ruleId":"122","severity":1,"message":"123","line":29,"column":54,"nodeType":"124","messageId":"125","endLine":29,"endColumn":55},{"ruleId":"110","severity":1,"message":"126","line":1,"col